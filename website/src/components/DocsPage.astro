---
import Layout from '../layouts/Layout.astro';
import Seo from './Seo.astro';
import { DOCS_LINKS, LINKS } from '../config/links';
import { useTranslations, type Locale } from '../i18n';

type Props = {
	locale: Locale;
};

const { locale } = Astro.props;
const t = useTranslations(locale).docsPage;
---

<Layout lang={locale}>
	<Seo slot="head" title={t.seoTitle} description={t.seoDescription} noindex={true} />

	<section class="mx-auto max-w-6xl px-4 py-12">
		<h1 class="text-3xl font-semibold tracking-tight text-slate-900">{t.title}</h1>
		<p class="mt-4 max-w-2xl text-slate-700">
			{t.lead}
		</p>

		<div class="mt-8 rounded-2xl border border-slate-200 bg-slate-50 p-6">
			<p class="text-sm font-semibold text-slate-900">{t.untilThen}</p>
			<ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-slate-700">
				<li>
					<a
						class="underline-offset-4 hover:underline"
						href={DOCS_LINKS.installation}
						target="_blank"
						rel="noreferrer"
					>
						{t.installation}
					</a>
				</li>
				<li>
					<a
						class="underline-offset-4 hover:underline"
						href={DOCS_LINKS.architecture}
						target="_blank"
						rel="noreferrer"
					>
						{t.architecture}
					</a>
				</li>
				<li>
					<a
						class="underline-offset-4 hover:underline"
						href={LINKS.githubRepo}
						target="_blank"
						rel="noreferrer"
					>
						{t.repository}
					</a>
				</li>
			</ul>
		</div>
	</section>
</Layout>
