---
// Starlight's default (unprefixed) locale reports as `undefined`, not 'de'.
const currentLocale = Astro.locals.starlightRoute.locale ?? 'de';
const otherLocale = currentLocale === 'de' ? 'en' : 'de';

// defaultLocale 'de' has no URL prefix (prefixDefaultLocale: false), 'en' is prefixed with /en/.
const pathWithoutLocalePrefix = Astro.url.pathname.replace(/^\/en(\/|$)/, '/');
const switchHref =
	otherLocale === 'en'
		? pathWithoutLocalePrefix.replace(/^\//, '/en/')
		: pathWithoutLocalePrefix;
---

<a
	href={switchHref}
	aria-label={Astro.locals.t('languageSelect.accessibleLabel')}
	title={Astro.locals.t('languageSelect.accessibleLabel')}
	class="sl-flex language-select-toggle"
>
	{otherLocale.toUpperCase()}
</a>

<style>
	.language-select-toggle {
		align-items: center;
		justify-content: center;
		height: 2.25rem;
		padding: 0 0.5rem;
		border-radius: 0.375rem;
		font-size: var(--sl-text-sm);
		color: var(--sl-color-gray-2);
		text-decoration: none;
	}
	.language-select-toggle:hover {
		color: var(--sl-color-white);
		background-color: var(--sl-color-gray-6);
	}
</style>
