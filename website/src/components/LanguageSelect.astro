---
// Starlight's default (unprefixed) locale reports as `undefined`, not 'en'.
const currentLocale = Astro.locals.starlightRoute.locale ?? 'en';
const otherLocale = currentLocale === 'en' ? 'de' : 'en';

// defaultLocale 'en' has no URL prefix (prefixDefaultLocale: false), 'de' is prefixed with /de/.
const pathWithoutLocalePrefix = Astro.url.pathname.replace(/^\/de(\/|$)/, '/');
const switchHref =
	otherLocale === 'de'
		? pathWithoutLocalePrefix.replace(/^\//, '/de/')
		: pathWithoutLocalePrefix;
---

<a
	href={switchHref}
	aria-label={Astro.locals.t('languageSelect.accessibleLabel')}
	title={Astro.locals.t('languageSelect.accessibleLabel')}
	class="sl-flex language-select-toggle"
>
	{otherLocale.toUpperCase()}
</a>

<style>
	.language-select-toggle {
		align-items: center;
		justify-content: center;
		height: 2.25rem;
		padding: 0 0.5rem;
		border-radius: 0.375rem;
		font-size: var(--sl-text-sm);
		color: var(--sl-color-gray-2);
		text-decoration: none;
	}
	.language-select-toggle:hover {
		color: var(--sl-color-white);
		background-color: var(--sl-color-gray-6);
	}
</style>
