---
import Layout from '../layouts/Layout.astro';
import Seo from './Seo.astro';
import { getCollection } from 'astro:content';
import { localizePath, useTranslations, type Locale } from '../i18n';

type Props = {
	locale: Locale;
};

const { locale } = Astro.props;
const t = useTranslations(locale).blogPage;

const posts = (await getCollection('blog'))
	.filter((p) => !p.data.draft && p.slug.startsWith(`${locale}/`))
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout lang={locale}>
	<Seo slot="head" title={t.seoTitle} description={t.seoDescription} />

	<section class="mx-auto max-w-6xl px-4 py-12">
		<div class="max-w-3xl">
			<h1 class="text-3xl font-semibold tracking-tight text-slate-900">{t.title}</h1>
			<p class="mt-3 text-slate-700">
				{t.lead}
			</p>
		</div>

		<div class="mt-10 grid gap-6 md:grid-cols-2">
			{posts.map((post) => (
				<a
					href={localizePath(`/blog/${post.slug.slice(`${locale}/`.length)}/`, locale)}
					class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-slate-300 hover:shadow"
				>
					<p class="text-xs font-semibold tracking-wide text-slate-500">
						{post.data.pubDate.toLocaleDateString(t.dateLocale, { year: 'numeric', month: 'short', day: '2-digit' })}
					</p>
					<h2 class="mt-2 text-lg font-semibold text-slate-900 group-hover:underline underline-offset-4">
						{post.data.title}
					</h2>
					<p class="mt-2 text-sm leading-relaxed text-slate-700">{post.data.description}</p>
				</a>
			))}
		</div>
	</section>
</Layout>
