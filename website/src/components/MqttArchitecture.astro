---
type Props = {
	id?: string;
};

const { id = 'architektur' } = Astro.props;
---

<section id={id} class="border-t border-slate-200 bg-white scroll-mt-24">
	<div class="mx-auto max-w-6xl px-4 py-14 md:py-16">
		<div class="space-y-10">
			<div class="space-y-4">
				<div class="space-y-2">
					<h2 class="text-2xl font-semibold tracking-tight text-slate-900">Aufbau</h2>
					<p class="text-slate-700">
						Beim Aufbau unseres Projekts haben wir besonders darauf geachtet, alles nutzerfreundlich, aber auch sicher und stabil zu halten.
						Unsere einzelnen Bestandteile sind:
					</p>
				</div>

				<ul class="space-y-3 text-sm text-slate-700">
					<li>
						<strong class="text-slate-900">Mobile App (Hauptbedienung)</strong>: eine einfache, nutzerfreundliche App für den Alltag (öffnen, buchen, Status sehen).
					</li>
					<li>
						<strong class="text-slate-900">Adminbereich</strong>: Verwaltung und Betrieb (Standorte, Geräte, Rollen, Support).
					</li>
					<li>
						<strong class="text-slate-900">Backend</strong>: prüft Berechtigungen, verwaltet Zustände und stellt die API bereit.
					</li>
					<li>
						<strong class="text-slate-900">MQTT Broker</strong>: entkoppelt das Backend und Schließfachstandort (Commands ↔ Status).
					</li>
					<li>
						<strong class="text-slate-900">IoT Client</strong>: läuft z.B. auf einem Raspberry Pi oder ESP und übersetzt Nachrichten in „echte“ Signale zum Schrank (z.B. Modbus).
					</li>
				</ul>
			</div>

			<figure class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
				<figcaption class="sr-only">Übersicht: Komponenten und Datenflüsse</figcaption>

				<div class="grid gap-4 lg:grid-cols-4">
					<div class="space-y-2">
						<p class="text-xs font-semibold tracking-wide text-slate-500">Benutzer &amp; Admin</p>
						<div class="space-y-2">
							<div class="rounded-xl border border-slate-200 bg-white p-3">
								<p class="text-sm font-semibold text-slate-900">Endbenutzer</p>
								<p class="mt-0.5 text-xs text-slate-600">nutzt die App</p>
							</div>
							<div class="rounded-xl border border-slate-200 bg-white p-3">
								<p class="text-sm font-semibold text-slate-900">Administrator</p>
								<p class="mt-0.5 text-xs text-slate-600">Admin UI</p>
							</div>
						</div>
					</div>

					<div class="space-y-2">
						<p class="text-xs font-semibold tracking-wide text-slate-500">Mobile App</p>
						<div class="rounded-xl border border-slate-200 bg-white p-3">
							<p class="text-sm font-semibold text-slate-900">Mobile App</p>
							<p class="mt-0.5 text-xs text-slate-600">Gegenstände buchen &amp; Schließfächer öffnen</p>
						</div>
					</div>

					<div class="space-y-2">
						<p class="text-xs font-semibold tracking-wide text-slate-500">Backend (open-locker.de)</p>
						<div class="space-y-2">
							<div class="rounded-xl border border-slate-200 bg-white p-3">
								<p class="text-sm font-semibold text-slate-900">Laravel Backend</p>
								<p class="mt-0.5 text-xs text-slate-600">API &amp; Admin Panel</p>
							</div>
							<div class="rounded-xl border border-emerald-200 bg-emerald-50 p-3">
								<p class="text-sm font-semibold text-emerald-950">MQTT Broker</p>
								<p class="mt-0.5 text-xs text-emerald-900/80">Mosquitto</p>
							</div>
							<div class="rounded-xl border border-slate-200 bg-white p-3">
								<p class="text-sm font-semibold text-slate-900">Datenbank</p>
								<p class="mt-0.5 text-xs text-slate-600">PostgreSQL / MySQL</p>
							</div>
						</div>
					</div>

					<div class="space-y-2">
						<p class="text-xs font-semibold tracking-wide text-slate-500">IoT (Standort)</p>
						<div class="space-y-2">
							<div class="rounded-xl border border-slate-200 bg-white p-3">
								<p class="text-sm font-semibold text-slate-900">Locker Client</p>
								<p class="mt-0.5 text-xs text-slate-600">Raspberry Pi / ESP</p>
							</div>
							<div class="rounded-xl border border-slate-200 bg-white p-3">
								<p class="text-sm font-semibold text-slate-900">Physische Schließfächer</p>
								<p class="mt-0.5 text-xs text-slate-600">Relais / Schloss</p>
							</div>
							<div class="rounded-xl border border-dashed border-slate-300 bg-white p-3">
								<div class="flex items-center justify-between gap-3">
									<p class="text-sm font-semibold text-slate-900">QR-Code Scanner</p>
									<span class="rounded-full bg-slate-100 px-2 py-0.5 text-[11px] font-semibold text-slate-700">Geplant</span>
								</div>
								<p class="mt-0.5 text-xs text-slate-600">direkt am Schrank</p>
							</div>
						</div>
					</div>
				</div>

				<div class="mt-6 space-y-3">
					<div class="rounded-xl border border-slate-200 bg-white p-4">
						<p class="text-xs font-semibold tracking-wide text-slate-500">Command (öffnen, reservieren, …)</p>
						<div class="mt-2 flex flex-wrap items-center gap-2 text-sm text-slate-800">
							<span class="rounded-full bg-slate-900 px-2.5 py-1 text-xs font-semibold text-white">HTTPS (REST)</span>
							<span class="font-medium">App</span>
							<span class="text-slate-400" aria-hidden="true">→</span>
							<span class="font-medium">Backend</span>
							<span class="text-slate-400" aria-hidden="true">→</span>
							<span class="rounded-full bg-emerald-100 px-2.5 py-1 text-xs font-semibold text-emerald-900">MQTT</span>
							<span class="font-medium">Broker</span>
							<span class="text-slate-400" aria-hidden="true">→</span>
							<span class="font-medium">Locker Client</span>
							<span class="text-slate-400" aria-hidden="true">→</span>
							<span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700">Modbus</span>
							<span class="font-medium">Schließfach</span>
						</div>
					</div>

					<div class="rounded-xl border border-slate-200 bg-white p-4">
						<p class="text-xs font-semibold tracking-wide text-slate-500">Status (Rückmeldung &amp; Live-Updates)</p>
						<div class="mt-2 flex flex-wrap items-center gap-2 text-sm text-slate-800">
							<span class="font-medium">Schließfach</span>
							<span class="text-slate-400" aria-hidden="true">→</span>
							<span class="font-medium">Locker Client</span>
							<span class="text-slate-400" aria-hidden="true">→</span>
							<span class="rounded-full bg-emerald-100 px-2.5 py-1 text-xs font-semibold text-emerald-900">MQTT</span>
							<span class="font-medium">Broker</span>
							<span class="text-slate-400" aria-hidden="true">→</span>
							<span class="font-medium">Backend</span>
							<span class="text-slate-400" aria-hidden="true">→</span>
							<span class="font-medium">Datenbank</span>
							<span class="text-slate-400" aria-hidden="true">·</span>
							<span class="rounded-full bg-slate-900 px-2.5 py-1 text-xs font-semibold text-white">Push/SSE</span>
							<span class="font-medium">App</span>
						</div>
					</div>
				</div>
			</figure>
		</div>
	</div>
</section>
