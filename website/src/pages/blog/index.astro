---
import Layout from '../../layouts/Layout.astro';
import Seo from '../../components/Seo.astro';
import { getCollection } from 'astro:content';

const title = 'Blog — Open Locker';
const description = 'Updates und Hintergrund aus dem Open Locker Projekt.';

const posts = (await getCollection('blog'))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout>
	<Seo slot="head" title={title} description={description} />

	<section class="mx-auto max-w-6xl px-4 py-12">
		<div class="max-w-3xl">
			<h1 class="text-3xl font-semibold tracking-tight text-slate-900">Blog</h1>
			<p class="mt-3 text-slate-700">
				Projekt-Updates, Release Notes und technische Deep Dives.
			</p>
		</div>

		<div class="mt-10 grid gap-6 md:grid-cols-2">
			{posts.map((post) => (
				<a
					href={`/blog/${post.slug}/`}
					class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-slate-300 hover:shadow"
				>
					<p class="text-xs font-semibold tracking-wide text-slate-500">
						{post.data.pubDate.toLocaleDateString('de-DE', { year: 'numeric', month: 'short', day: '2-digit' })}
					</p>
					<h2 class="mt-2 text-lg font-semibold text-slate-900 group-hover:underline underline-offset-4">
						{post.data.title}
					</h2>
					<p class="mt-2 text-sm leading-relaxed text-slate-700">{post.data.description}</p>
				</a>
			))}
		</div>
	</section>
</Layout>

