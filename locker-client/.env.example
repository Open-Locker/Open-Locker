# Locker Client deployment defaults
#
# Copy this file to .env before starting docker compose:
# cp .env.example .env

# Container image tag to deploy.
# Keep "latest" for the simplest setup or pin a tagged release like "1.2.3".
LOCKER_CLIENT_IMAGE_TAG=latest

# Provisioning token for first-time device provisioning.
# Leave empty after the locker has already been provisioned.
PROVISIONING_TOKEN=

# Watchtower polling interval in seconds.
WATCHTOWER_POLL_INTERVAL=300

# Timezone used by Watchtower logs and schedules.
TZ=UTC

# Optional runtime overrides for the client container.
# DATA_DIR=/data
# CONFIG_DIR=/config
# MQTT_CLIENT_ID=
# LOG_LEVEL=info
