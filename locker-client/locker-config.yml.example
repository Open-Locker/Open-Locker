# Locker Client Configuration File
# This file should be mounted as a Docker volume at /config/locker-config.yml
# It contains local device/bootstrap settings only.
# Server-managed runtime values such as heartbeat interval and compartment mapping
# are stored separately in the runtime config overlay under /data.

# Modbus RTU Configuration
modbus:
  # Serial port for Modbus communication (required)
  # All boards on the shared RS485 bus use this port
  port: /dev/ttyACM0

  # Optional serial defaults for the shared bus
  baudRate: 9600
  dataBits: 8
  stopBits: 1
  parity: none
  timeout: 1000

  # Relay pulse duration in milliseconds for native Waveshare flash commands
  # The board applies flash timing in 100ms steps, so values are rounded up
  flashDurationMs: 200
