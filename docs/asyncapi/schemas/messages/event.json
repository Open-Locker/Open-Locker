{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./event.json",
  "title": "MQTT event envelope",
  "type": "object",
  "required": [
    "message_id",
    "event",
    "timestamp"
  ],
  "properties": {
    "message_id": {
      "$ref": "../common/message-id.json"
    },
    "event": {
      "type": "string",
      "minLength": 1
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "$ref": "../common/timestamp.json"
    },
    "data": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
