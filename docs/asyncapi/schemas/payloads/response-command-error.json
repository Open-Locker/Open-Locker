{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./response-command-error.json",
  "title": "Failed command response",
  "allOf": [
    {
      "$ref": "../messages/response.json"
    },
    {
      "type": "object",
      "required": [
        "result",
        "error_code",
        "message"
      ],
      "properties": {
        "result": {
          "const": "error"
        },
        "error_code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  ]
}
