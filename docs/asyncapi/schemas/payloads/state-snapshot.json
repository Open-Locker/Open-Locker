{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./state-snapshot.json",
  "title": "Aggregated retained locker snapshot",
  "allOf": [
    {
      "$ref": "../messages/state.json"
    },
    {
      "type": "object",
      "required": [
        "state",
        "data"
      ],
      "properties": {
        "state": {
          "const": "snapshot"
        },
        "data": {
          "type": "object",
          "required": [
            "compartments"
          ],
          "properties": {
            "compartments": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "compartment_id",
                  "relay_state",
                  "lock_state",
                  "door_sensor",
                  "door_state"
                ],
                "properties": {
                  "compartment_id": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "relay_state": {
                    "type": "string",
                    "enum": [
                      "ON",
                      "OFF"
                    ]
                  },
                  "lock_state": {
                    "type": "string",
                    "enum": [
                      "UNLOCKED",
                      "LOCKED"
                    ]
                  },
                  "door_sensor": {
                    "type": "string",
                    "enum": [
                      "TRIGGERED",
                      "IDLE"
                    ]
                  },
                  "door_state": {
                    "type": "string",
                    "enum": [
                      "OPEN",
                      "CLOSED"
                    ]
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": true
        }
      }
    }
  ]
}
