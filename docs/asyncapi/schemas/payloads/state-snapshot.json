{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./state-snapshot.json",
  "title": "Aggregated retained compartment snapshot",
  "description": "A retained full snapshot of all configured compartments, published on locker/{locker_uuid}/state/compartments. Publish after the first successful state poll and afterwards only when at least one effective compartment door_state changes. Use door_state=unknown for configured compartments that cannot be read reliably.",
  "allOf": [
    {
      "$ref": "../messages/state.json"
    },
    {
      "type": "object",
      "required": [
        "compartments"
      ],
      "properties": {
        "compartments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "compartment_number",
              "door_state"
            ],
            "properties": {
              "compartment_number": {
                "type": "integer",
                "minimum": 1
              },
              "door_state": {
                "type": "string",
                "enum": [
                  "open",
                  "closed",
                  "unknown"
                ]
              }
            },
            "additionalProperties": false
          },
          "minItems": 0
        }
      }
    }
  ]
}
