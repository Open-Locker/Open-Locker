{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./state-snapshot.json",
  "title": "Aggregated retained compartment snapshot",
  "allOf": [
    {
      "$ref": "../messages/state.json"
    },
    {
      "type": "object",
      "required": [
        "state",
        "data"
      ],
      "properties": {
        "state": {
          "const": "compartment_snapshot"
        },
        "data": {
          "type": "object",
          "required": [
            "compartments"
          ],
          "properties": {
            "compartments": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "compartment_number",
                  "door_state"
                ],
                "properties": {
                  "compartment_number": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "door_state": {
                    "type": "string",
                    "enum": [
                      "open",
                      "closed",
                      "unknown"
                    ]
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": true
        }
      }
    }
  ]
}
