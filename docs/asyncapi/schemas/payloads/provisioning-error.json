{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./provisioning-error.json",
  "title": "Failed provisioning reply",
  "allOf": [
    {
      "$ref": "../messages/provisioning-reply.json"
    },
    {
      "type": "object",
      "required": [
        "status",
        "message"
      ],
      "properties": {
        "status": {
          "const": "error"
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  ]
}
