{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./response-apply-config-success.json",
  "title": "Successful apply_config response",
  "allOf": [
    {
      "$ref": "./response-command-success.json"
    },
    {
      "type": "object",
      "required": [
        "action",
        "applied_config_hash"
      ],
      "properties": {
        "action": {
          "const": "apply_config"
        },
        "applied_config_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        }
      }
    }
  ]
}
