---
import Layout from '../layouts/Layout.astro';
import Seo from '../components/Seo.astro';

const title = 'Impressum — Open-Locker';
const description = 'Impressum für die Open-Locker Website.';
---

<Layout lang="de">
	<Seo slot="head" title={title} description={description} noindex={false} />

	<section class="mx-auto max-w-6xl px-4 py-12">
		<h1 class="text-3xl font-semibold tracking-tight text-slate-900">Impressum</h1>

		<article class="prose prose-slate mt-8 max-w-none">
			<p>
				<strong>Platzhalter:</strong> Bitte trage hier die rechtlich erforderlichen Angaben ein (Anbieter, Anschrift,
				Kontakt, Vertretungsberechtigte, Registereintrag/Steuernummer falls relevant).
			</p>

			<h2>Kontakt</h2>
			<ul>
				<li>E-Mail: <em>[bitte eintragen]</em></li>
				<li>Adresse: <em>[bitte eintragen]</em></li>
			</ul>

			<h2>Haftung für Inhalte</h2>
			<p>
				<em>[bitte eintragen]</em>
			</p>

			<h2>Haftung für Links</h2>
			<p>
				<em>[bitte eintragen]</em>
			</p>
		</article>
	</section>
</Layout>

