---
import Layout from '../layouts/Layout.astro';
import Seo from '../components/Seo.astro';
import UseCasesMarquee from '../components/UseCasesMarquee.astro';
import Partners from '../components/Partners.astro';
import MeetingPolaroids from '../components/MeetingPolaroids.astro';
import ProjectOverview from '../components/ProjectOverview.astro';
import MqttArchitecture from '../components/MqttArchitecture.astro';
import Pricing from '../components/Pricing.astro';
import discordWordmark from '../assets/Discord-Logo-White.svg';
import githubLockup from '../assets/GitHub_Lockup_Black.svg';
import githubMark from '../assets/GitHub_Invertocat_Black.svg';
import { DOCS_LINKS, LINKS } from '../config/links';

const title = 'Open Locker — Open Source Software für Schließfächer';
const description =
	'Open Locker ist ein Open Source Projekt für Software und Hardwarebaupläne von öffentlichen Schließfächern zum Lagern und Teilen von Gegenständen.';

const INSTALLATION_URL = DOCS_LINKS.installation;
---

<Layout>
	<Seo slot="head" title={title} description={description} />

	<section id="start" class="border-b border-slate-200 bg-linear-to-b from-slate-50 to-white scroll-mt-24">
		<div class="mx-auto max-w-6xl px-4 py-14 md:py-20">
			<div class="max-w-2xl space-y-6">
				<p class="text-sm font-semibold tracking-wide text-slate-600">Ein Mitwirkprojekt der Smart City Hameln-Pyrmont</p>
				<h1 class="text-4xl font-semibold tracking-tight text-slate-900 md:text-5xl">
					<span class="block">Open Locker</span>
					<span class="mt-2 block">Der smarte Schrank für alle.</span>
				</h1>
				<p class="text-lg leading-relaxed text-slate-700">
					Eine Open Source Toolbox, um kostengünstige, digitale Schließfachsysteme selbst zu bauen, zu teilen und zu verwalten.
				</p>

				<div class="space-y-4">
					<div class="flex flex-wrap gap-3">
						<a
							href="#mehr-erfahren"
							class="rounded-md bg-slate-900 px-4 py-2.5 text-sm font-medium text-white hover:bg-slate-800 focus-visible:ring-2 focus-visible:ring-slate-900"
						>
							Mehr erfahren
						</a>
						<a
							href={INSTALLATION_URL}
							target="_blank"
							rel="noreferrer"
							class="rounded-md border border-slate-300 bg-white px-4 py-2.5 text-sm font-medium text-slate-900 hover:bg-slate-50 focus-visible:ring-2 focus-visible:ring-slate-900"
						>
							Losbauen
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<ProjectOverview />

	<UseCasesMarquee />

	<MqttArchitecture id="technik" />

	<section id="mitmachen" class="border-t border-slate-200 bg-slate-50 scroll-mt-24">
		<div class="relative overflow-hidden">
			<div class="pointer-events-none absolute inset-0">
				<div class="absolute inset-0 bg-linear-to-br from-slate-50/85 via-white/55 to-slate-100/80"></div>
				<MeetingPolaroids variant="spreadBackground" />
			</div>

			<div class="relative z-10 mx-auto max-w-6xl px-4 py-14 md:py-16">
				<div class="max-w-2xl rounded-2xl border border-slate-200 bg-white/90 p-8 shadow-sm backdrop-blur-sm md:p-10">
					<div class="space-y-4">
						<div class="space-y-2">
							<h2 class="text-2xl font-semibold tracking-tight text-slate-900">Du willst mitmachen?</h2>
							<p class="text-slate-700">
								Komm auf Discord in die Runde oder schnapp dir ein Issue auf GitHub. Wir helfen dir gerne beim Einstieg.
							</p>
						</div>

						<div class="flex flex-wrap gap-3">
							<a
								href={LINKS.discordInvite}
								target="_blank"
								rel="noreferrer"
								class="inline-flex items-center rounded-md bg-[#5865F2] px-4 py-2.5 text-sm font-medium text-white hover:bg-[#4752C4] focus-visible:ring-2 focus-visible:ring-blue-600"
								aria-label="Discord öffnen"
							>
								<img
									src={discordWordmark.src}
									width="132"
									height="20"
									class="h-5 w-auto"
									alt=""
									aria-hidden="true"
									loading="lazy"
								/>
							</a>
							<a
								href={LINKS.githubRepo + '/issues'}
								target="_blank"
								rel="noreferrer"
								class="inline-flex items-center gap-2 rounded-md border border-slate-300 bg-white px-4 py-2.5 text-sm font-medium text-slate-900 hover:bg-slate-50 focus-visible:ring-2 focus-visible:ring-blue-600"
							>
								<img
									src={githubMark.src}
									width="20"
									height="20"
									class="h-5 w-5"
									alt=""
									aria-hidden="true"
									loading="lazy"
								/>
								<span>Issues ansehen</span>
							</a>
						</div>

						<p class="text-sm text-slate-600">
							Hier ein paar echte Eindrücke von unseren Live Treffen im Hintergrund. Termine werden im Discord besprochen.
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<Pricing installationUrl={INSTALLATION_URL} contactHref="#kontakt" />

	<section id="kontakt" class="border-t border-slate-200 bg-slate-50 scroll-mt-24">
		<div class="mx-auto max-w-6xl px-4 py-14 md:py-16">
			<div class="rounded-2xl border border-slate-200 bg-white p-8">
				<h2 class="text-2xl font-semibold tracking-tight text-slate-900">Kontakt</h2>
				<p class="mt-3 text-slate-700">
					Am schnellsten erreichst du uns über Discord oder GitHub. Für formale Anfragen schreib uns eine
					<a
						class="font-medium text-slate-900 underline-offset-4 hover:underline"
						href={'mailto:' + LINKS.contactEmail}
					>
						E-Mail
					</a>.
				</p>

				<div class="mt-6 flex flex-wrap gap-3">
					<a
						href={LINKS.discordInvite}
						target="_blank"
						rel="noreferrer"
						class="inline-flex items-center rounded-md bg-[#5865F2] px-4 py-2.5 text-sm font-medium text-white hover:bg-[#4752C4] focus-visible:ring-2 focus-visible:ring-blue-600"
						aria-label="Discord öffnen"
					>
						<img
							src={discordWordmark.src}
							width="132"
							height="20"
							class="h-5 w-auto"
							alt=""
							aria-hidden="true"
							loading="lazy"
						/>
					</a>
					<a
						href={LINKS.githubRepo}
						target="_blank"
						rel="noreferrer"
						class="inline-flex items-center rounded-md border border-slate-300 bg-white px-4 py-2.5 text-sm font-medium text-slate-900 hover:bg-slate-50 focus-visible:ring-2 focus-visible:ring-blue-600"
						aria-label="GitHub öffnen"
					>
						<img
							src={githubLockup.src}
							width="88"
							height="20"
							class="h-5 w-auto max-w-44"
							alt=""
							aria-hidden="true"
							loading="lazy"
						/>
					</a>
					<a
						href={LINKS.githubRepo + '/issues'}
						target="_blank"
						rel="noreferrer"
						class="inline-flex items-center gap-2 rounded-md border border-slate-300 bg-white px-4 py-2.5 text-sm font-medium text-slate-900 hover:bg-slate-50 focus-visible:ring-2 focus-visible:ring-blue-600"
					>
						<img
							src={githubMark.src}
							width="20"
							height="20"
							class="h-5 w-5"
							alt=""
							aria-hidden="true"
							loading="lazy"
						/>
						<span>Issue erstellen</span>
					</a>
				</div>

			</div>
		</div>
	</section>

	<Partners />
</Layout>
