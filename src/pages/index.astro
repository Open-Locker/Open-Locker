---
import Layout from '../layouts/Layout.astro';
import Seo from '../components/Seo.astro';
import DiscordMeetingInfo from '../components/DiscordMeetingInfo.astro';
import UseCasesMarquee from '../components/UseCasesMarquee.astro';
import Partners from '../components/Partners.astro';
import { DOCS_LINKS, LINKS } from '../config/links';

const title = 'Open Locker — Open-Source-Software für Schließfächer';
const description =
	'Open Locker ist ein Open-Source-Projekt für Software und Hardware-Baupläne von öffentlichen Schließfächern zum Lagern und Teilen von Gegenständen.';

const INSTALLATION_URL = DOCS_LINKS.installation;
---

<Layout>
	<Seo slot="head" title={title} description={description} />

	<section id="start" class="border-b border-slate-200 bg-linear-to-b from-slate-50 to-white scroll-mt-24">
		<div class="mx-auto max-w-6xl px-4 py-14 md:py-20">
			<div class="max-w-2xl space-y-6">
				<p class="text-sm font-semibold tracking-wide text-slate-600">Open Source · Self-hostable · Community-driven</p>
				<h1 class="text-4xl font-semibold tracking-tight text-slate-900 md:text-5xl">
					Open Locker
				</h1>
				<p class="text-lg leading-relaxed text-slate-700">
					Baut und betreibt öffentliche Schließfächer, die einfach zu nutzen, gut anpassbar und offen entwickelt sind —
					von der Backend-API über die Mobile App bis zum Hardware-Bauplan.
				</p>

				<div class="space-y-4">
					<div class="flex flex-wrap gap-3">
						<a
							href="#mehr-erfahren"
							class="rounded-md bg-slate-900 px-4 py-2.5 text-sm font-medium text-white hover:bg-slate-800 focus-visible:ring-2 focus-visible:ring-slate-900"
						>
							Mehr erfahren
						</a>
						<a
							href={INSTALLATION_URL}
							target="_blank"
							rel="noreferrer"
							class="rounded-md border border-slate-300 bg-white px-4 py-2.5 text-sm font-medium text-slate-900 hover:bg-slate-50 focus-visible:ring-2 focus-visible:ring-slate-900"
						>
							Losbauen
						</a>
					</div>
					<DiscordMeetingInfo discordUrl={LINKS.discordInvite} />
				</div>
			</div>
		</div>
	</section>

	<UseCasesMarquee />

	<section id="mehr-erfahren" class="mx-auto max-w-6xl px-4 py-14 md:py-20 scroll-mt-24">
		<div class="grid gap-10 md:grid-cols-3">
			<div class="space-y-2">
				<h2 class="text-lg font-semibold text-slate-900">Für Betreiber</h2>
				<p class="text-slate-700">
					Betreibt ein zuverlässiges System mit Admin-Panel, Mobile App und Integrationen für den echten Alltag.
				</p>
			</div>
			<div class="space-y-2">
				<h2 class="text-lg font-semibold text-slate-900">Für Mitwirkende</h2>
				<p class="text-slate-700">
					Verbessert Backend, App und Hardware-Dokumentation. Issues und PRs sind willkommen.
				</p>
			</div>
			<div class="space-y-2">
				<h2 class="text-lg font-semibold text-slate-900">Für Communities</h2>
				<p class="text-slate-700">
					Teilt und verleiht Equipment lokal — mit transparenter, anpassbarer Infrastruktur.
				</p>
			</div>
		</div>
	</section>

	<section id="technik" class="border-t border-slate-200 bg-white scroll-mt-24">
		<div class="mx-auto max-w-6xl px-4 py-14 md:py-16">
			<div class="grid gap-10 md:grid-cols-2 md:items-start">
				<div class="space-y-3">
					<h2 class="text-2xl font-semibold tracking-tight text-slate-900">Technik auf einen Blick</h2>
					<p class="text-slate-700">
						Open Locker umfasst Software, App und Hardware-Baupläne — du kannst klein starten und später erweitern.
					</p>
				</div>
				<div class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
					<ul class="space-y-3 text-sm text-slate-700">
						<li>
							<strong class="text-slate-900">Backend</strong>: Laravel 11 API mit Filament Admin-Panel
						</li>
						<li>
							<strong class="text-slate-900">Mobile App</strong>: Flutter App für Nutzer:innen
						</li>
						<li>
							<strong class="text-slate-900">Hardware</strong>: Raspberry Pi + Modbus-Kommunikation zu den Schließfächern
						</li>
						<li>
							<strong class="text-slate-900">IoT-Stack</strong>: MQTT-Broker mit HTTP-Auth via Backend
						</li>
						<li>
							<strong class="text-slate-900">Docs</strong>: Architektur + Installations-Guides
						</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<section id="mitmachen" class="border-t border-slate-200 bg-slate-50 scroll-mt-24">
		<div class="mx-auto max-w-6xl px-4 py-14 md:py-16">
			<div class="rounded-2xl border border-slate-200 bg-white p-8 md:flex md:items-center md:justify-between md:gap-8">
				<div class="space-y-2">
					<h2 class="text-2xl font-semibold tracking-tight text-slate-900">Du willst mitmachen?</h2>
					<p class="text-slate-700">
						Komm auf Discord in die Runde oder schnapp dir ein Issue auf GitHub — wir helfen dir gern beim Einstieg.
					</p>
				</div>
				<div class="mt-6 flex flex-wrap gap-3 md:mt-0">
					<a
						href={LINKS.discordInvite}
						target="_blank"
						rel="noreferrer"
						class="rounded-md bg-slate-900 px-4 py-2.5 text-sm font-medium text-white hover:bg-slate-800 focus-visible:ring-2 focus-visible:ring-blue-600"
					>
						Discord beitreten
					</a>
					<a
						href={LINKS.githubRepo + '/issues'}
						target="_blank"
						rel="noreferrer"
						class="rounded-md border border-slate-300 bg-white px-4 py-2.5 text-sm font-medium text-slate-900 hover:bg-slate-50 focus-visible:ring-2 focus-visible:ring-blue-600"
					>
						Issues ansehen
					</a>
				</div>
			</div>
		</div>
	</section>

	<section id="kosten" class="border-t border-slate-200 bg-white scroll-mt-24">
		<div class="mx-auto max-w-6xl px-4 py-14 md:py-16">
			<div class="grid gap-10 md:grid-cols-2 md:items-start">
				<div class="space-y-3">
					<h2 class="text-2xl font-semibold tracking-tight text-slate-900">Kosten</h2>
					<p class="text-slate-700">
						Open Locker ist Open Source. Die Software selbst ist kostenlos — Kosten entstehen typischerweise durch
						Hosting/Betrieb, Hardware und ggf. Support.
					</p>
				</div>
				<div class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
					<ul class="space-y-3 text-sm text-slate-700">
						<li><strong class="text-slate-900">Software</strong>: kostenlos (Open Source)</li>
						<li><strong class="text-slate-900">Betrieb</strong>: Server/Monitoring/Backups (je nach Setup)</li>
						<li><strong class="text-slate-900">Hardware</strong>: Schließfächer, Raspberry Pi, Modbus, Netzwerk</li>
						<li><strong class="text-slate-900">Support</strong>: optional (Community oder Partner)</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<section id="kontakt" class="border-t border-slate-200 bg-slate-50 scroll-mt-24">
		<div class="mx-auto max-w-6xl px-4 py-14 md:py-16">
			<div class="rounded-2xl border border-slate-200 bg-white p-8">
				<h2 class="text-2xl font-semibold tracking-tight text-slate-900">Kontakt</h2>
				<p class="mt-3 text-slate-700">
					Am schnellsten erreichst du uns über Discord oder GitHub. Für formale Anfragen schreib uns eine E-Mail.
				</p>

				<div class="mt-6 flex flex-wrap gap-3">
					<a
						href={LINKS.discordInvite}
						target="_blank"
						rel="noreferrer"
						class="rounded-md bg-slate-900 px-4 py-2.5 text-sm font-medium text-white hover:bg-slate-800 focus-visible:ring-2 focus-visible:ring-blue-600"
					>
						Discord
					</a>
					<a
						href={LINKS.githubRepo}
						target="_blank"
						rel="noreferrer"
						class="rounded-md border border-slate-300 bg-white px-4 py-2.5 text-sm font-medium text-slate-900 hover:bg-slate-50 focus-visible:ring-2 focus-visible:ring-blue-600"
					>
						GitHub
					</a>
					<a
						href={LINKS.githubRepo + '/issues'}
						target="_blank"
						rel="noreferrer"
						class="rounded-md border border-slate-300 bg-white px-4 py-2.5 text-sm font-medium text-slate-900 hover:bg-slate-50 focus-visible:ring-2 focus-visible:ring-blue-600"
					>
						Issue erstellen
					</a>
				</div>

				<p class="mt-6 text-sm text-slate-600">
					E-Mail:{' '}
					<a
						class="font-medium text-slate-900 underline-offset-4 hover:underline"
						href={'mailto:' + LINKS.contactEmail}
					>
						{LINKS.contactEmail}
					</a>
				</p>
			</div>
		</div>
	</section>

	<Partners />
</Layout>
