---
import Server from '@lucide/astro/icons/server';
import BadgeCheck from '@lucide/astro/icons/badge-check';
import Leaf from '@lucide/astro/icons/leaf';
import MapPin from '@lucide/astro/icons/map-pin';

type Props = {
  id?: string;
  contactHref?: string;
};

const { id = 'hosting', contactHref = '#kontakt' } = Astro.props;
---

<section id={id} class="mt-14 scroll-mt-24">
	<div class="rounded-2xl border border-slate-200 bg-linear-to-br from-slate-900 to-slate-800 p-8 text-white">
		<div class="grid gap-8 md:grid-cols-2 md:items-start">
		<div class="space-y-4">
			<div class="space-y-3">
				<h3 class="text-xl font-semibold tracking-tight">Keine Lust auf selber hosten?</h3>
				<p class="text-slate-200">
					Wenn ihr Open Locker nicht selbst betreiben wollt, aber trotzdem von den Vorteilen (Open Source, Anpassbarkeit,
					Transparenz) profitieren möchtet, hosten wir das zentrale Backend für euch in Deutschland und auf Ökostrom.
					Damit reduziert ihr Betriebsaufwand und unterstützt direkt die Weiterentwicklung des Projekts.
				</p>
			</div>

			<div class="flex flex-wrap gap-3">
				<a
					href={contactHref}
					class="rounded-md bg-white px-4 py-2.5 text-sm font-medium text-slate-900 hover:bg-slate-100 focus-visible:ring-2 focus-visible:ring-white"
				>
					Kontakt aufnehmen
				</a>
			</div>
		</div>

		<ul class="space-y-3 text-sm text-slate-200">
			<li class="flex items-start gap-3">
				<Server class="mt-0.5 h-5 w-5 text-white" aria-hidden="true" />
				<div>
					<p class="font-semibold text-white">Zentrales Backend</p>
					<p class="mt-1 text-slate-200">Wir hosten das Backend für euch, damit ihr nicht bei null anfangen müsst.</p>
				</div>
			</li>
			<li class="flex items-start gap-3">
				<MapPin class="mt-0.5 h-5 w-5 text-white" aria-hidden="true" />
				<div>
					<p class="font-semibold text-white">Hosting in Deutschland</p>
					<p class="mt-1 text-slate-200">Kurze Wege, klare Zuständigkeiten und ein Setup, das zu EU-Anforderungen passt.</p>
				</div>
			</li>
			<li class="flex items-start gap-3">
				<BadgeCheck class="mt-0.5 h-5 w-5 text-white" aria-hidden="true" />
				<div>
					<p class="font-semibold text-white">DSGVO-konform</p>
					<p class="mt-1 text-slate-200">Betrieb und Datenverarbeitung mit Fokus auf Datenschutz und Compliance.</p>
				</div>
			</li>
			<li class="flex items-start gap-3">
				<Leaf class="mt-0.5 h-5 w-5 text-white" aria-hidden="true" />
				<div>
					<p class="font-semibold text-white">Ökostrom</p>
					<p class="mt-1 text-slate-200">Betrieb auf Infrastruktur mit erneuerbarer Energie.</p>
				</div>
			</li>
			<li class="flex items-start gap-3">
				<BadgeCheck class="mt-0.5 h-5 w-5 text-white" aria-hidden="true" />
				<div>
					<p class="font-semibold text-white">Support für Open Locker</p>
					<p class="mt-1 text-slate-200">Euer Hosting-Beitrag fließt in Wartung, Verbesserungen und neue Features.</p>
				</div>
			</li>
		</ul>
		</div>
	</div>
</section>

