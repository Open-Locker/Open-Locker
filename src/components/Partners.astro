---
import { LINKS } from '../config/links';
---

<section aria-labelledby="partners-title" class="bg-white">
	<div class="mx-auto max-w-6xl px-4 py-12">
		<div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
			<h2 id="partners-title" class="text-lg font-semibold tracking-tight text-slate-900">
				Unterstützt und entwickelt durch
			</h2>

			<div class="flex flex-col items-start gap-5 sm:flex-row sm:flex-wrap sm:items-center sm:justify-end">
				{LINKS.partners.map((partner) => (
					<a
						href={partner.url}
						target="_blank"
						rel="noreferrer"
						class="inline-flex items-center justify-center rounded-md px-2 py-1 focus-visible:ring-2 focus-visible:ring-blue-600"
						aria-label={partner.name}
						title={partner.name}
					>
						<img
							src={partner.logoSrc}
							alt={partner.name}
							loading="lazy"
							class="h-10 w-auto max-w-56 object-contain md:h-12"
						/>
					</a>
				))}
			</div>
		</div>
	</div>
</section>

