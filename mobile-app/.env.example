# Select one of: development | preview | production
APP_VARIANT=development

# Shared base identifier (fallback for both platforms).
# For store releases set this to your final reverse-DNS identifier.
APP_ID_BASE=com.openlocker.mobileapp

# Optional platform-specific overrides. Keep commented out unless needed.
# APP_ID_BASE_IOS=com.openlocker.mobileapp
# APP_ID_BASE_ANDROID=com.openlocker.mobileapp

# App semantic version exposed in app config.
APP_VERSION=1.0.0

# Apple Developer Team ID (required for iOS store builds/submission).
# EXPO_APPLE_TEAM_ID=ABCDE12345

# Expo EAS project id (required for EAS cloud build/submit).
# EXPO_EAS_PROJECT_ID=your-eas-project-id

# API base URL including protocol; /api suffix is auto-normalized when missing.
# EXPO_PUBLIC_API_BASE_URL=https://open-locker.cloud/api

# Reverb (realtime) connection — the app connects directly to Reverb, not via
# /api. Values must match the backend REVERB_* the client uses. The host is
# derived from EXPO_PUBLIC_API_BASE_URL by default (so the Android emulator's
# 10.0.2.2 works automatically); only set EXPO_PUBLIC_REVERB_HOST to override.
# EXPO_PUBLIC_REVERB_KEY=open-locker-key
# EXPO_PUBLIC_REVERB_PORT=8080
# EXPO_PUBLIC_REVERB_SCHEME=http
# EXPO_PUBLIC_REVERB_HOST=        # optional; defaults to the API host
