{
  "name": "mobile-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "start:go": "expo start",
    "android:go": "expo start --android",
    "ios:go": "expo start --ios",
    "lint": "expo lint",
    "test": "jest --watch",
    "test:ci": "jest --ci --runInBand",
