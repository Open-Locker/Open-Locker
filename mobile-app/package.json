    "typecheck": "tsc --noEmit",
    "doctor": "npx expo-doctor",
    "react-doctor": "npx react-doctor@latest --full --verbose",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run doctor",
    "generate:api": "rtk-query-codegen-openapi openapi-codegen.config.js && pnpm run typecheck",
