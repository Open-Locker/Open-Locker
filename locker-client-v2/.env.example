# locker-client-v2 — copy to .env for local development:
#   cp .env.example .env
#
# In Docker, mount /config/locker-config.yml and /data (or set CONFIG_DIR / DATA_DIR).

# --- First-time provisioning (required until .provisioning-state exists) ---
PROVISIONING_TOKEN=

# Bootstrap MQTT credentials (used only during provisioning; not the device credentials)
MQTT_DEFAULT_USERNAME=provisioning_client
MQTT_DEFAULT_PASSWORD=a_public_password

# --- Runtime connectivity ---
MQTT_BROKER_URL=mqtt://open-locker.cloud

# Optional: stable MQTT client identity (defaults to generated ID in DATA_DIR)
# MQTT_CLIENT_ID=

# --- Paths (defaults match Docker layout) ---
# DATA_DIR=/data
# CONFIG_DIR=/config

# --- Logging ---
LOG_LEVEL=info
